---
import Header from "../components/Header.astro";
import "../styles/global.css";

const {
  title = "Rogier de Boevé - Creative Developer",
  description = "Portfolio of Rogier de Boevé, Belgium-based creative developer",
} = Astro.props;

const pathname = Astro.url.pathname;
const pageClass = pathname === "/" ? "is-home" : pathname.startsWith("/about") ? "is-about" : "is-project";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <script is:inline>
      document.documentElement.classList.add("js");
      try {
        if (window.sessionStorage.getItem("rd:has-entered") === "true") {
          document.documentElement.classList.add("has-session-entered");
        }
      } catch {}
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/open-graph.jpg" />
  </head>
  <body class={`is-preloading ${pageClass}`}>
    <script is:inline>
      try {
        if (window.sessionStorage.getItem("rd:has-entered") === "true") {
          document.documentElement.classList.add("has-session-entered");
          document.body.classList.remove("is-preloading");
          document.body.classList.add("has-entered");
        }
      } catch {}
    </script>
    <div class="preloader c-color">
      <div class="preloader-progress">
        <div class="preloader-cta" data-sound="true">
          <div class="preloader-cta-text">
            <div class="preloader-cta-text-inner">
              <div class="preloader-cta-text-static">Enter</div>
              <div class="preloader-cta-text-hover">Enter</div>
            </div>
          </div>
        </div>
        <svg class="preloader-progress-circles" width="462" height="462" viewBox="0 0 462 462" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle class="preloader-progress-outline" opacity="0.4" cx="231" cy="231" r="224" stroke="currentColor" stroke-dasharray="2 2"></circle>
          <circle class="preloader-progress-circle" opacity="0.5" cx="231" cy="231" r="230" stroke="currentColor"></circle>
        </svg>
        <div class="preloader-progress-text">
          <div class="preloader-progress-text-inner"><div class="preloader-progress-text-percent">0</div>%</div>
        </div>
        <div class="preloader-cta-2" data-sound="false">
          <div class="preloader-cta-2-text">
            <div class="preloader-cta-text-2-inner">
              <div class="preloader-cta-text-2-static">Enter without sound</div>
            </div>
          </div>
        </div>
      </div>
      <div class="preloader-footer">
        <div class="wrap">
          <div class="flex justify-end">
            <div class="preloader-footer-text">
              <div class="preloader-footer-text-inner">
                Loading<span class="preloader-footer-text-dots">...</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="gl" data-webgl-root></div>
    <Header />
    <main class="ui-main">
      <slot />
    </main>
    <div class="ui-sound-toggle c-color" data-sound-click>
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect class="ui-sound-toggle-static" x="0.5" y="0.5" width="27" height="27" rx="13.5" stroke="currentColor" stroke-opacity="0.5" stroke-dasharray="2 2"></rect>
        <g class="ui-sound-toggle-hover-wrap">
          <rect class="ui-sound-toggle-hover" x="0.5" y="0.5" width="27" height="27" rx="13.5" stroke="currentColor" stroke-opacity="1"></rect>
        </g>
        <g class="ui-sound-toggle-rects">
          <rect x="6.125" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="7" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="7.875" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="8.75" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="9.625" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="10.5" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="11.375" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="12.25" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="13.125" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="14" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="14.875" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="15.75" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="16.625" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="17.5" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="18.375" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="19.25" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
          <rect x="20.125" y="14" width="1.75" height="1.75" rx="0.875" fill="currentColor"></rect>
        </g>
      </svg>
    </div>
    <script>
      import "../client/main.ts";
    </script>
  </body>
</html>
