---
const pathname = Astro.url.pathname;
---

<header class="ui-header">
  <div class="ui-header-bg"></div>
  <div class="ui-header-secondary">
    <div class="wrap">
      <div class="grid grid-cols-24 gap-24">
        <div class="col-span-4">
          <a href="/" class="ui-header-version ts-m c-color">V-004</a>
        </div>
        <div class="col-span-7 col-start-18 ui-header-availability ts-m c-color">Available for freelance</div>
      </div>
    </div>
  </div>

  <div class="ui-header-primary">
    <div class="wrap">
      <div class="grid grid-cols-24 gap-24">
        <div class="col-span-4">
          <a href="/" class="ui-header-name c-color" aria-label="Rogier de Boeve">
            <span>Rogier</span>
            <span>de Boeve</span>
          </a>
        </div>
        <div class="col-span-4 col-start-5">
          <div class="ui-header-description c-color">
            <span>Creative</span>
            <span>Developer</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <nav class="ui-nav-mobile c-color" aria-label="Mobile navigation">
    <button class="ui-nav-mobile-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" data-menu-toggle>
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="ui-nav-mobile-panel">
      <a class={pathname === "/" ? "is-active" : ""} href="/">Work</a>
      <a class={pathname.startsWith("/about") ? "is-active" : ""} href="/about/">About</a>
    </div>
  </nav>
</header>

<nav class="ui-nav" aria-label="Main navigation">
  <div class="wrap">
    <ul>
      <li><a class={`ui-nav-a c-color ${pathname === "/" ? "is-active" : ""}`} href="/"><span>01</span><span>Work</span></a></li>
      <li><a class={`ui-nav-a c-color ${pathname.startsWith("/about") ? "is-active" : ""}`} href="/about/"><span>02</span><span>About</span></a></li>
    </ul>
  </div>
</nav>
