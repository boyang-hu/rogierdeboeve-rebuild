---
const pathname = Astro.url.pathname;
---

<header class="ui-header">
  <div class="ui-header-bg"></div>
  <div class="ui-header-secondary">
    <div class="wrap">
      <div class="grid grid-cols-24 gap-24">
        <div class="col-span-4">
          <a href="/" class="ui-header-version ts-m c-color">V-004</a>
        </div>
        <div class="col-span-6 col-start-19 ui-header-availability ts-m c-color">
          <span class="ui-header-part-outer"><span class="ui-header-part-inner">Available for freelance</span></span>
        </div>
      </div>
    </div>
  </div>

  <div class="ui-header-primary">
    <div class="wrap">
      <div class="grid grid-cols-24 gap-24">
        <div class="col-span-4">
          <a href="/" class="ui-header-name c-color" aria-label="Rogier de Boevé">
            <span>Rogier</span>
            <span>de Boevé</span>
          </a>
        </div>
        <div class="col-span-4 col-start-5">
          <div class="ui-header-description c-color">
            <span class="ui-header-part-outer"><span class="ui-header-part-inner">Creative</span></span>
            <span class="ui-header-part-outer"><span class="ui-header-part-inner">Developer</span></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <nav class="ui-nav-mobile c-color" aria-label="Mobile navigation">
    <button class="ui-nav-mobile-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" data-menu-toggle>
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="ui-nav-mobile-panel">
      <a class={`ui-nav-mobile-a ${pathname === "/" ? "is-active" : ""}`} href="/" data-slug="work">
        <span class="ui-nav-mobile-a-inner">Work</span>
      </a>
      <a class={`ui-nav-mobile-a ${pathname.startsWith("/about") ? "is-active" : ""}`} href="/about/" data-slug="about">
        <span class="ui-nav-mobile-a-inner">About</span>
      </a>
    </div>
  </nav>
</header>

<nav class="ui-nav" aria-label="Main navigation">
  <div class="wrap">
    <ul>
      <li>
        <a class={`ui-nav-a c-color ${pathname === "/" ? "is-active" : ""}`} href="/" data-slug="work">
          <span class="ui-nav-a-icon" aria-hidden="true"><svg class="c-icon-arrow-xs" width="6" height="6" viewBox="0 0 6 6"><rect rx="1" width="2" height="2" fill="currentColor"></rect><rect rx="1" x="3.4" y="2" width="2" height="2" fill="currentColor"></rect><rect rx="1" y="4" width="2" height="2" fill="currentColor"></rect></svg></span>
          <span class="ui-nav-a-inner">
            <span class="ui-nav-a-title">Work</span>
          </span>
        </a>
      </li>
      <li>
        <a class={`ui-nav-a c-color ${pathname.startsWith("/about") ? "is-active" : ""}`} href="/about/" data-slug="about">
          <span class="ui-nav-a-icon" aria-hidden="true"><svg class="c-icon-arrow-xs" width="6" height="6" viewBox="0 0 6 6"><rect rx="1" width="2" height="2" fill="currentColor"></rect><rect rx="1" x="3.4" y="2" width="2" height="2" fill="currentColor"></rect><rect rx="1" y="4" width="2" height="2" fill="currentColor"></rect></svg></span>
          <span class="ui-nav-a-inner">
            <span class="ui-nav-a-title">About</span>
          </span>
        </a>
      </li>
    </ul>
  </div>
</nav>
