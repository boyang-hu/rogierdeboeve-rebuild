---
import type { MediaItem } from "../types";

const {
  item,
  class: className = "",
  mode = "track",
  parallax = "",
} = Astro.props as { item: MediaItem; class?: string; mode?: "track" | "mobile"; parallax?: "top" | "bottom" | "" };
const width = Number(item.size.width || 1600);
const height = Number(item.size.height || 1200);
const ratioHeight = Math.round(height * 0.95);
const ratio = `${width} / ${ratioHeight}`;
const jpg = item.src.replace(/\.(webp|jpg|jpeg)$/i, ".jpg");
---

{mode === "track" ? (
  <div
    class={className}
    data-media
    data-media-parallax={parallax}
    data-media-src={item.src}
    data-media-width={width}
    data-media-height={height}
    style={`aspect-ratio: ${ratio};`}
  />
) : (
  <div class={className} style={`aspect-ratio: ${ratio};`}>
    {item.type === "video" ? (
      <video src={item.src} autoplay muted loop playsinline style="object-fit: cover; width: 100%; height: 100%;"></video>
    ) : (
      <picture>
        <source srcset={item.src} type="image/webp" />
        <source srcset={jpg} type="image/jpeg" />
        <img src={item.src} loading="lazy" alt={item.alt} />
      </picture>
    )}
  </div>
)}
