---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import { recognitionSummary } from "../data/site";
---

<BaseLayout title="About - Rogier de Boeve">
  <section data-view="about" class="ui-about">
    <div class="wrap wrap--md">
      <div class="ui-about-hero grid grid-cols-24 gap-24">
        <div class="ui-about-hero-visual col-span-7 col-start-6" data-about-model></div>
        <div class="col-span-8 col-start-14">
          <h1 class="ui-title ts-m c-color"><span>About me</span></h1>
          <div class="ui-about-intro">
            <p class="ts-1">Independent Freelance Creative Developer & Digital Designer</p>
            <p class="ts-p">Belgium-based creative developer and digital designer, passionate about digital art, creative coding, and 3D animation.</p>
            <p class="ts-p">Always looking for interesting freelance opportunities to develop beautiful digital experiences.</p>
          </div>
        </div>
      </div>

      <div class="ui-about-collab grid grid-cols-24 gap-24">
        <div class="col-span-8 col-start-6">
          <h2 class="ts-m">Brands I've worked for</h2>
          <p class="ts-p">Marvel Studios, Coca-Cola, Nike,<br />Jaeger-LeCoultre, ABC TV,<br />T-Mobile, Postman, De Morgen,<br />DreamWorks, On Running.</p>
        </div>
        <div class="col-span-8 col-start-14">
          <h2 class="ts-m">Agencies I've worked with</h2>
          <p class="ts-p">Dogstudio, Immersive Garden,<br />North Kingdom, Thoughtlab,<br />Reflektor Digital, Mortierbrigade,<br />Powster, ToyFight.</p>
        </div>
      </div>

      <div class="ui-about-recognition grid grid-cols-24 gap-24">
        <div class="col-span-16 col-start-6">
          <h2 class="ts-m">Recognition</h2>
          <div class="c-list ts-m">
            {recognitionSummary.map((group) => (
              <div class="c-list-section grid grid-cols-16 gap-24">
                <div class="c-list-section-title">{group.title}</div>
                <div class="c-list-items">
                  {group.items.map(([title, amount]) => (
                    <div class="c-list-item">
                      <div class="c-list-item-title">{title}</div>
                      <div class="c-list-item-amount">{amount}</div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="ui-about-contact grid grid-cols-24 gap-24">
        <div class="col-span-7 col-start-6">
          <h2 class="ts-m">Services</h2>
          <ul class="ts-p">
            <li>WebGL Development</li>
            <li>Frontend Development</li>
            <li>Digital Design</li>
            <li>Motion Design</li>
          </ul>
        </div>
        <div class="col-span-8 col-start-14">
          <h2 class="ts-m">Contact</h2>
          <p class="ts-2">Reach out for<br />freelance collaborations<br />or just to <a href="mailto:hello@rogierdeboeve.com">say hi</a>.</p>
        </div>
      </div>
    </div>
    <Footer />
  </section>
</BaseLayout>
