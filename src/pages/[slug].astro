---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Footer from "../components/Footer.astro";
import MediaBlock from "../components/MediaBlock.astro";
import { getNextProject, getProjectBySlug, projects, thumbSrc } from "../data/site";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { slug: project.data.slug },
  }));
}

const { slug } = Astro.props;
const project = getProjectBySlug(slug);
if (!project) {
  return Astro.redirect("/");
}
const nextProject = getNextProject(project);
const [hero, ...restMedia] = project.data.content;
const colorValue = (value?: string) => {
  if (!value) return undefined;
  return value.startsWith("#") ? value : `#${value}`;
};
const projectColor = colorValue(project.data.colors.primary) ?? "#bcbcbc";
const projectSecondary = colorValue(project.data.colors.secondary) ?? projectColor;
const projectMedia = colorValue(project.data.colors.media) ?? projectColor;
const projectBlocks = colorValue(project.data.colors.blocks);
---

<BaseLayout title={`${project.data.title} - Rogier de Boevé`} description={project.data.description.replace(/<[^>]+>/g, "")}>
  <section
    data-view="project"
    class="ui-project"
    data-project={project.data.slug}
    data-webgl-project
    data-color={projectColor}
    data-secondary={projectSecondary}
    data-invert={colorValue(project.data.colors.invert)}
    data-media-color={projectMedia}
    data-blocks={projectBlocks}
    data-thumb={thumbSrc(project)}
    data-darkness={project.data.thumbnail.darkness ?? project.data.darkenDetail}
    data-darkness-color={colorValue(project.data.thumbnail.darknessColor)}
    data-saturation={project.data.thumbnail.saturation ?? project.data.saturation}
    data-contrast={project.data.contrast}
    data-mouse-lightness={project.data.thumbnail.mouseLightness}
    data-ambient={project.data.ambient}
    style={`--project-color:${projectColor};--project-secondary:${projectSecondary};--project-media:${projectMedia}`}
  >
    <div class="ui-project-header c-color">
      <div class="wrap">
        <a href="/" class="c-link" data-sound data-sound-click>
          <span class="c-link-icon" aria-hidden="true">
            <span class="c-link-icon-bg">
              <svg class="c-icon-arrow" width="28" height="28" viewBox="0 0 28 28">
                <rect x="0.5" y="0.5" width="27" height="27" fill="none" stroke="currentColor" stroke-dasharray="2 2"></rect>
              </svg>
            </span>
            <span class="c-link-icon-static">
              <svg class="c-icon-arrow" width="28" height="28" viewBox="0 0 28 28">
                <g fill="currentColor">
                  <rect rx="1" x="11.3" y="11" width="2" height="2"></rect>
                  <rect rx="1" x="14.7" y="13" width="2" height="2"></rect>
                  <rect rx="1" x="11.3" y="15" width="2" height="2"></rect>
                </g>
              </svg>
            </span>
          </span>
          <span class="c-link-text">To index</span>
        </a>
      </div>
    </div>

    <div class="wrap wrap--md">
      <div class="grid grid-cols-24 gap-24">
        <div class="col-span-20 col-start-5 ui-project-content">
          <div class="ui-project-content-header">
            <div class="grid grid-cols-20 gap-24">
              <div class="col-span-6">
                <h1 class="ts-2 c-color">{project.data.title}</h1>
              </div>
              <div class="col-span-12 col-start-7">
                <p class="ts-p c-color" set:html={project.data.description}></p>
              </div>
            </div>

            {hero && <MediaBlock item={hero} class="ui-project-media-mobile" mode="mobile" />}

            <div class="ui-project-info grid grid-cols-20 gap-24">
              <div class="col-span-6">
                {project.data.url && <Button text="View live" href={project.data.url} target="_blank" rel="noopener" />}
              </div>
              <div class="ui-project-info-items col-span-12 col-start-7 c-color">
                {project.data.client && <div class="ui-project-info-item"><span>Client:</span><span>{project.data.client}</span></div>}
                {project.data.agency && <div class="ui-project-info-item"><span>Agency:</span><span>{project.data.agency}</span></div>}
                {project.data.role && <div class="ui-project-info-item"><span>Role:</span><span>{project.data.role}</span></div>}
                {project.data.year && <div class="ui-project-info-item"><span>Year:</span><span>{project.data.year}</span></div>}
              </div>
            </div>
          </div>

          <div class="ui-project-media-items ui-project-media-items--desktop grid grid-cols-20 gap-24">
            {project.data.content.map((item, index) => (
              <MediaBlock item={item} class={index === 0 ? "ui-project-media col-span-12 col-start-7" : "ui-project-media col-span-18"} />
            ))}
          </div>

          <div class="ui-project-media-items ui-project-media-items--mobile">
            {restMedia.map((item) => (
              <MediaBlock item={item} class="ui-project-media-mobile" mode="mobile" />
            ))}
          </div>

          <div class="ui-project-next" data-project-slug={nextProject.data.slug}>
            <a href={`/${nextProject.data.slug}/`} class="ui-project-next-link c-color">
              <span class="ts-m">Next project</span>
              <h2 class="ts-3">{nextProject.data.title}</h2>
              {nextProject.data.content[0] && (
                <>
                  <MediaBlock item={nextProject.data.content[0]} class="ui-project-next-image" parallax="bottom" />
                  <MediaBlock item={nextProject.data.content[0]} class="ui-project-media-mobile ui-project-next-mobile" mode="mobile" />
                </>
              )}
            </a>
          </div>
        </div>
      </div>
    </div>
    <div class="c-scroll-cta c-color">
      <div class="wrap wrap--md">
        <div class="grid grid-cols-24 gap-24">
          <div class="col-span-8 col-start-5">
            <div class="c-scroll-cta-inner">
              <span class="c-scroll-cta-icon" aria-hidden="true">
                <svg class="c-icon-arrow-xs" width="6" height="6" viewBox="0 0 6 6">
                  <rect rx="1" width="2" height="2" fill="currentColor"></rect>
                  <rect rx="1" x="3.4" y="2" width="2" height="2" fill="currentColor"></rect>
                  <rect rx="1" y="4" width="2" height="2" fill="currentColor"></rect>
                </svg>
              </span>
              <span class="c-scroll-cta-text ts-m">Scroll Down</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <Footer />
    <div class="ui-scrollbar c-color" aria-hidden="true">
      <div class="ui-scrollbar-thumb"><div class="ui-scrollbar-thumb-inner"></div></div>
      <div class="ui-scrollbar-total"></div>
    </div>
  </section>
</BaseLayout>
